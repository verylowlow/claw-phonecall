# AgentCallCenter Configuration
# Copy to .env and fill in values

# Backend type: mock | sim800c | sim7600 | usb_modem | android
BRIDGE_BACKEND=mock

# OpenClaw voice-call plugin endpoints
VOICE_CALL_STREAM_URL=ws://127.0.0.1:3334/voice/stream
VOICE_CALL_WEBHOOK_URL=http://127.0.0.1:3334/voice/webhook

# Twilio-compatible credentials (voice-call uses these to authenticate)
TWILIO_ACCOUNT_SID=LOCAL_BRIDGE
TWILIO_AUTH_TOKEN=local_token

# SIMCom module (when BRIDGE_BACKEND=sim800c or sim7600)
# SIM800C: typically one COM port for both AT and audio
# SIM7600: AT port and audio port are separate (check Device Manager)
# SIMCOM_AT_PORT=COM3
# SIMCOM_AUDIO_PORT=         # leave empty for SIM800C (shared port)
# SIMCOM_BAUD_RATE=115200

# USB Voice Modem (when BRIDGE_BACKEND=usb_modem)
# MODEM_PORT=COM3
# MODEM_BAUD_RATE=115200

# Android backend (when BRIDGE_BACKEND=android)
# ANDROID_DEVICE_ID=
