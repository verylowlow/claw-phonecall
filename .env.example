# 复制此文件为 .env 后填写，切勿提交 .env

# 火山引擎流式 ASR（三项必填其一不可缺）
VOLC_ASR_APP_KEY=
VOLC_ASR_ACCESS_TOKEN=
VOLC_ASR_SECRET_KEY=

# 可选：外部工具绝对路径（未设置则 scrcpy 会尝试项目内 scrcpy-win64-v3.3.3，ffmpeg/adb 依赖 PATH）
# AGENTCALLS_SCRCPY=D:/path/to/scrcpy.exe
# AGENTCALLS_FFMPEG=D:/path/to/ffmpeg.exe
# AGENTCALLS_ADB=D:/path/to/adb.exe

# OpenClaw Gateway（Phone Skill 句末调用 /v1/responses 取整段回复）
# OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789
# OPENCLAW_GATEWAY_TOKEN=
# OPENCLAW_AGENT_ID=main
# OPENCLAW_SESSION_USER=13800138000

# 未配置 Gateway 时的占位话术（可选）
# PHONE_SKILL_MOCK_REPLY=好的，请继续说。
